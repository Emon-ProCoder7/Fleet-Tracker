    {
      "parameters": {
        "jsCode": "// Central Dhaka coordinates bounds\nconst latMin = 23.7200;\nconst latMax = 23.7900;\nconst lonMin = 90.3700;\nconst lonMax = 90.4300;\n\nfunction getRandom(min, max) {\n  return (Math.random() * (max - min) + min).toFixed(6);\n}\n\n// Generate random starts and ends\nconst startLon = getRandom(lonMin, lonMax);\nconst startLat = getRandom(latMin, latMax);\nconst endLon = getRandom(lonMin, lonMax);\nconst endLat = getRandom(latMin, latMax);\n\n// Pass vehicle info from webhook along with new coordinates\nreturn [{\n  json: {\n    name: $('Webhook').item.json.body.name || \"Test Vehicle\",\n    type: $('Webhook').item.json.body.type || \"car\",\n    start: `${startLon},${startLat}`,\n    end: `${endLon},${endLat}`\n  }\n}];\n"
      },
