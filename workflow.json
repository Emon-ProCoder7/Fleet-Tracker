    {
      "parameters": {
        "jsCode": "const updatedVehicles = [];\n\nfor (const item of $input.all()) {\n  const vehicle = item.json;\n  \n  let coordinates = [];\n  try {\n    coordinates = typeof vehicle.route_geometry === 'string' \n      ? JSON.parse(vehicle.route_geometry) \n      : vehicle.route_geometry;\n  } catch (e) {\n    continue; \n  }\n\n  if (!coordinates || coordinates.length === 0) continue;\n\n  // Advance index by 1, stop at the final destination point\n  let nextIndex = (vehicle.current_index || 0) + 1;\n  if (nextIndex >= coordinates.length) {\n    nextIndex = coordinates.length - 1; \n  }\n\n  // OpenRouteService gives coordinates as [longitude, latitude]\n  const [nextLon, nextLat] = coordinates[nextIndex];\n\n  updatedVehicles.push({\n    json: {\n      id: vehicle.id,\n      current_index: nextIndex,\n      latitude: nextLat,\n      longitude: nextLon\n    }\n  });\n}\n\nreturn updatedVehicles;\n"
      },
